# Servidor
PORT=3000

# CORS (lista separada por virgula)
# Exemplo: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN=http://localhost:3000

# Autenticacao Basic opcional para /api/*
AUTH_ENABLED=false

# Formato: usuario:senha:perfil,usuario2:senha2:perfil2
# Perfis de escrita aceitos: admin, operator
AUTH_USERS=admin:trocar_senha:admin
